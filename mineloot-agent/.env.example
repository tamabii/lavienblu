# MineLoot Mining Configuration Template
# Copy this file to .env and fill in your values

# === Wallet (REQUIRED) ===
# Your wallet private key (0x-prefixed, 64 hex chars)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Wallet address (for reporting)
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS

# === Network (Base Mainnet) ===
BASE_RPC=https://mainnet.base.org
# Or use Alchemy for better reliability:
# BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# === Mining Config ===
# Total ETH to deploy per round
DEPLOY_ETH=0.00025

# ETH per block (0.00025 / 25 blocks)
ETH_PER_BLOCK=0.00001

# Number of blocks to mine (1-25)
BLOCKS_COUNT=25

# === Contract Addresses (Base Mainnet) ===
GRID_MINING=0xA8E2F506aDcbBF18733A9F0f32e3D70b1A34d723
LOOT_TOKEN=0x00E701Eff4f9Dc647f1510f835C5d1ee7E41D28f
AUTO_MINER=0x4b99Ebe4F9220Bd5206199b10dFC039a6a73eDBC
