# APoW Mining Configuration Template
# Copy this file to .env and fill in your values

# === Wallet (REQUIRED) ===
# Your wallet private key (0x-prefixed, 64 hex chars)
# Generate with: npx apow-cli wallet new
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# === RPC (Base Mainnet) ===
# Option 1: Use Alchemy (recommended, free)
# Get key at: https://dashboard.alchemy.com
RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Option 2: Use QuickNode x402 (auto-pay $10 USDC)
# USE_X402=true

# === LLM Config (Required for Minting) ===
# LLM provider: openai, anthropic, gemini, deepseek, qwen
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-api-key-here

# === Contract Addresses (Base Mainnet) ===
# These are mainnet addresses - do not change
MINING_AGENT_ADDRESS=0xB7caD3ca5F2BD8aEC2Eb67d6E8D448099B3bC03D
AGENT_COIN_ADDRESS=0x12577CF0D8a07363224D6909c54C056A183e13b3

# === Optional ===
# For bridging from Solana
# SQUID_INTEGRATOR_ID=your_squid_id
